{
  "name": "fluxer-selfbot.js",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun build ./index.ts --outdir ./dist --target node --minify",
    "clean": "rm -rf dist",
    "docs:dev": "vitepress dev wiki",
    "docs:build": "typedoc && vitepress build wiki",
    "docs:mcp": "typedoc --json ./dist/mcp-context.json",
    "mcp:run": "bun run src/mcp-server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typedoc-vitepress-theme": "^1.1.2",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": [
        "./index.ts"
    ],
    "out": "wiki/api",
    "name": "Fluxer-Selfbot.js APIReference",
    "includeVersion": true,
    "plugin": [
        "typedoc-plugin-markdown"
    ],
    "hideGenerator": true,
    "excludePrivate": true,
    "excludeProtected": false,
    "excludeExternals": true,
    "cleanOutputDir": true,
    "readme": "none",
    "entryFileName": "index.md"
}